<div class="modal fade" id="spkModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable">
    <div class="modal-content rounded-4 shadow-lg">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title fw-bold">Smart Study Planner Assessment</h5>
        <button
          type="button"
          class="btn-close btn-close-white"
          data-bs-dismiss="modal"
        ></button>
      </div>

      <div class="modal-body p-4">
        <small class="text-muted mb-4">
          Isi data berikut untuk mendapatkan rekomendasi pola dan waktu belajar
          optimal berdasarkan kondisi Anda menggunakan metode SAW dan pendekatan
          Explainable AI.
        </small>

        <form action="/hitung" method="POST">
          <h6 class="fw-bold mb-3">Identitas Responden</h6>

          <div class="row">
            <div class="mb-3">
              <label class="form-label">Nama Lengkap</label>
              <input type="text" name="nama" class="form-control" required />
            </div>

            <div class="col-md-6 mb-3">
              <label class="form-label">Jenis Kelamin</label>
              <select name="gender" class="form-select" required>
                <option value="">Pilih</option>
                <option value="L">Laki-laki</option>
                <option value="P">Perempuan</option>
              </select>
            </div>

            <div class="col-md-6 mb-3">
              <label class="form-label">Usia</label>
              <input type="number" name="usia" class="form-control" required />
            </div>

            <div class="col-md-6 mb-3">
              <label class="form-label">Status</label>
              <select name="status" class="form-select" required>
                <option value="">Pilih</option>
                <option value="Pelajar">Pelajar</option>
                <option value="Mahasiswa">Mahasiswa</option>
                <option value="Pekerja">Pekerja</option>
                <option value="Umum">Umum</option>
              </select>
            </div>

            <div class="col-md-6 mb-4">
              <label class="form-label">Aktivitas Utama</label>
              <select name="aktivitas" class="form-select" required>
                <option value="">Pilih</option>
                <option value="Sekolah">Sekolah</option>
                <option value="Kuliah">Kuliah</option>
                <option value="Bekerja">Bekerja</option>
                <option value="Kuliah Sambil Bekerja">Kuliah & Bekerja</option>
              </select>
            </div>
          </div>

          <hr class="my-4" />

          <h6 class="fw-bold mb-3">Penilaian Kondisi Belajar</h6>

          <p class="text-muted small mb-3">
            Berikan penilaian sesuai kondisi Anda saat ini
          </p>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Tingkat konsentrasi saat belajar
            </label>
            <small class="text-muted d-block mb-1">
              1 (Sangat sulit fokus) – 5 (Sangat mudah fokus)
            </small>
            <select name="konsentrasi" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">Sangat sulit fokus</option>
              <option value="2">Sulit fokus</option>
              <option value="3">Cukup fokus</option>
              <option value="4">Mudah Fokus</option>
              <option value="5">Sangat mudah fokus</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold"> Konsistensi belajar </label>
            <small class="text-muted d-block mb-1">
              1 (Tidak pernah belajar) – 5 (Sangat rutin belajar)
            </small>
            <select name="konsistensi" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">Tidak pernah</option>
              <option value="2">Jarang</option>
              <option value="3">Kadang-kadang</option>
              <option value="4">Sering</option>
              <option value="5">Sangat rutin</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Durasi belajar per sesi
            </label>
            <small class="text-muted d-block mb-1">
              1 (Kurang dari 30 menit) – 5 (Lebih dari 3 jam)
            </small>
            <select name="durasi" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">&lt; 30 menit</option>
              <option value="2">30 – 60 menit</option>
              <option value="3">1 – 2 jam</option>
              <option value="4">2 – 3 jam</option>
              <option value="5">&gt; 3 jam</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Tingkat kelelahan saat belajar
            </label>
            <small class="text-muted d-block mb-1">
              1 (Tidak Mudah lelah) – 5 (Sangat cepat lelah)
            </small>
            <select name="kelelahan" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">Tidak mudah lelah</option>
              <option value="2">Sedikit lelah</option>
              <option value="3">Cukup lelah</option>
              <option value="4">Cepat lelah</option>
              <option value="5">Sangat cepat lelah</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Kondisi lingkungan belajar
            </label>
            <small class="text-muted d-block mb-1">
              1 (Sangat mengganggu) – 5 (Sangat kondusif)
            </small>
            <select name="lingkungan" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">Sangat mengganggu</option>
              <option value="2">Kurang kondusif</option>
              <option value="3">Cukup kondusif</option>
              <option value="4">Kondusif</option>
              <option value="5">Sangat kondusif</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Frekuensi distraksi saat belajar
            </label>
            <small class="text-muted d-block mb-1">
              1 (Sangat sering) – 5 (Sangat jarang)
            </small>
            <select name="gangguan" class="form-select" required>
              <option value="">Pilih</option>
              <option value="1">Sangat sering</option>
              <option value="2">Sering</option>
              <option value="3">Kadang-kadang</option>
              <option value="4">Jarang</option>
              <option value="5">Sangat jarang</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">
              Waktu luang utama untuk belajar
            </label>
            <small class="text-muted d-block mb-1">
              Pilih waktu anda yang sering kosong
            </small>
            <select name="waktu_luang" class="form-select" required>
              <option value="">Pilih</option>
              <option value="pagi">Pagi</option>
              <option value="siang">Siang</option>
              <option value="sore">Sore</option>
              <option value="malam">Malam</option>
            </select>
          </div>

          <div class="d-grid mt-4">
            <small class="text-muted small">
              Sistem akan menghasilkan rekomendasi berdasarkan kondisi Anda dan
              memberikan penjelasan keputusan.
            </small>

            <button type="submit" class="btn btn-success btn-lg rounded-pill">
              Lihat Rekomendasi
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
