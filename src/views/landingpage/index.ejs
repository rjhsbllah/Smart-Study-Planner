 

  <section class="py-lg-13 py-8 bg-white position-relative" id="hero">
    <div class="circle-bg d-none d-lg-block"></div>
    <div class="container ">
      <div class="row align-items-center gy-8">
        <div class="col-lg-6">
          <h1 class="display-3 fw-bold mt-4">
            Optimalkan Waktu Belajar Anda
            <span class="text-primary">Secara Cerdas</span>
            Kapan Saja, Di Mana Saja
          </h1>
          <p class="my-6 lead fw-normal">
            Temukan pola dan waktu belajar yang paling cocok untuk Anda. Belajar jadi lebih efektif, terarah, dan sesuai dengan kebutuhan Anda.
          </p>

          <div class="d-flex gap-6 mt-8">
            <div class="d-flex align-items-center gap-2">
              <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  class="icon icon-tabler icons-tabler-users text-primary">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  <path d="M21 21v-2a4 4 0 0 0 -3 -3.85" />
                </svg>
              </span>
              <small class="mb-0">
                <span class="fw-bold"><%= totalResponden %></span> Responden
              </small>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-3 rounded-5  shadow-sm">
            <div class="position-relative">
              <div class="position-relative">
                <img src="./assets/images/tumbnail.png" alt="about" class="rounded-5 img-fluid" />

                <a href="https://youtu.be/dOBWRedNTP0"
                  class="play-btn glightbox position-absolute top-50 start-50 translate-middle icon-shape icon-xl rounded-circle text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
                    class="icon icon-tabler icons-tabler-filled icon-tabler-player-play">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" />
                  </svg>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
  </section>
  
  <section class="py-lg-13 py-8 bg-white position-relative" id="riwayat">
    <div class="container">
      
      <div class="text-center mb-10">
        <span class="text-primary text-uppercase small fw-semibold">
          Riwayat
        </span>
        <h2 class="fw-bold mt-3">
          Rekomendasi <span class="text-primary">Terbaru</span>
        </h2>
        <p class="text-muted">
          Lihat hasil rekomendasi belajar dari pengguna lainnya
        </p>
      </div>

      <div class="row g-4">

        <% if (riwayat && riwayat.length > 0) { %>

          <% riwayat.forEach(item => { %>
            <div class="col-lg-4 col-md-6">
              <div class="card border-0 shadow-sm rounded-5 h-100 p-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                  <h6 class="fw-bold mb-0"><%= item.nama %></h6>
                  <span class="badge bg-primary bg-opacity-10 text-primary">
                    <%= item.skor %>
                  </span>
                </div>

                <h5 class="fw-semibold mb-2">
                  <%= item.rekomendasi.judul %>
                </h5>

                <p class="small text-muted mb-1">
                  <strong>Waktu:</strong> <%= item.rekomendasi.waktu %>
                </p>

                <p class="small text-muted mb-3">
                  <strong>Pola:</strong> <%= item.rekomendasi.pola %>
                </p>

                <a href="#"
                  class="btn-detail"

                  data-nama="<%= item.nama %>"
                  data-skor="<%= item.skor %>"
                  data-judul="<%= item.rekomendasi.judul %>"
                  data-waktu="<%= item.rekomendasi.waktu %>"
                  data-pola="<%= item.rekomendasi.pola %>"
                  data-deskripsi="<%- item.rekomendasi.deskripsi %>"

                  data-gender="<%= item.gender %>"
                  data-usia="<%= item.usia %>"
                  data-status="<%= item.status %>"
                  data-aktivitas="<%= item.aktivitas %>"

                  data-waktu_luang="<%= item.waktu_luang %>"
                  data-konsentrasi="<%= item.konsentrasi %>"
                  data-konsistensi="<%= item.konsistensi %>"
                  data-durasi="<%= item.durasi %>"
                  data-kelelahan="<%= item.kelelahan %>"
                  data-lingkungan="<%= item.lingkungan %>"
                  data-gangguan="<%= item.gangguan %>"

                  data-tips='<%- JSON.stringify(item.rekomendasi.tips || []) %>'
                  data-alasan='<%- JSON.stringify(item.rekomendasi.alasan || []) %>'
                  data-faktor='<%- JSON.stringify(item.rekomendasi.faktor || []) %>'>

                  Lihat detail →
                </a>

              </div>
            </div>
          <% }) %>

        <% } else { %>

          <div class="col-12 text-center">
            <p class="text-muted">Belum ada data hasil rekomendasi</p>
          </div>

        <% } %>
      </div>
    </div>
  </section>
  
  <section class="py-lg-13 py-8 bg-light bg-opacity-50" id="faq">
    <div class="container">
      <div class="accordion-container" id="accordion"></div>
    </div>
  </section>

  

