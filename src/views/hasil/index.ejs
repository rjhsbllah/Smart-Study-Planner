<div class="container my-5">
  <div class="text-center mb-5">
    <h2 class="fw-bold">Hasil Rekomendasi Belajar</h2>
    <p class="text-muted">
      Analisis kebiasaan belajar & rekomendasi personal untuk kamu
    </p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="p-4 text-center text-white header-gradient">
          <h3 class="fw-bold mb-1"><%= data.nama %></h3>
          <div class="mt-2">
            <span class="badge bg-light text-dark me-2"><%= data.status %></span>
            <span class="badge bg-light text-dark"><%= data.aktivitas %></span>
          </div>
        </div>

        <div class="text-center py-4">
          <h6 class="text-muted mb-2">Skor Performa Belajar</h6>

          <div class="score-wrapper">
            <div class="score-circle">
              <%= skor %>%
            </div>
          </div>

          <p class="mt-3 fw-semibold">
            <% if (skor >= 80) { %>
              Sangat Optimal
            <% } else if (skor >= 60) { %>
              Cukup Baik
            <% } else { %>
              Perlu Perbaikan
            <% } %>
          </p>

          <p class="text-muted small">
            <% if (skor >= 80) { %>
              Kondisi belajar kamu sudah sangat baik dan efektif.
            <% } else if (skor >= 60) { %>
              Kondisi belajar cukup baik namun masih bisa ditingkatkan.
            <% } else { %>
              Kondisi belajar perlu diperbaiki agar lebih optimal.
            <% } %>
          </p>
        </div>

        <hr class="mx-4"/>

        <div class="px-4 pb-4">

          <h5 class="fw-bold text-center mb-4">Rekomendasi Belajar</h5>

          <% if (rekomendasi) { %>

          <div class="row g-3 mb-4">

            <div class="col-md-6">
              <div class="p-3 border rounded-3 bg-light text-center">
                <small class="text-muted">Metode</small>
                <h6 class="fw-bold mt-1"><%= rekomendasi.judul %></h6>
              </div>
            </div>

            <div class="col-md-6">
              <div class="p-3 border rounded-3 bg-light text-center">
                <small class="text-muted">Waktu Ideal</small>
                <h6 class="fw-bold mt-1"><%= rekomendasi.waktu %></h6>
              </div>
            </div>

            <div class="col-12">
              <div class="p-3 border rounded-3 bg-light">
                <small class="text-muted">Pola Belajar</small>
                <p class="mb-0"><%= rekomendasi.pola %></p>
              </div>
            </div>

          </div>

          <div class="mb-4">
            <h6 class="fw-bold">Jadwal Belajar</h6>

            <% if (rekomendasi.jadwal && rekomendasi.jadwal.length > 0) { %>
              <div class="p-3 border rounded-3 bg-light">

                <% rekomendasi.jadwal.forEach(item => { %>

                  <div class="d-flex justify-content-between align-items-center mb-2 p-2 rounded" style="background: <%= item.type === 'Belajar' ? '#e8f5e9' : '#fff3e0' %>">

                    <div>
                      <%= item.type === "Belajar" ? "Sesi " + item.sesi : "Istirahat" %>
                    </div>

                    <div class="fw-semibold">
                      <%= item.waktu %>
                    </div>

                  </div>

                <% }) %>

              </div>
            <% } else { %>
              <p class="text-muted">Jadwal belum tersedia</p>
            <% } %>
          </div>

          <% if (rekomendasi.faktor && rekomendasi.faktor.length > 0) { %>
          <div class="mb-4">
            <h6 class="fw-bold">Faktor Utama</h6>
            <div class="d-flex flex-wrap gap-2 mt-2">
              <% rekomendasi.faktor.forEach(f => { %>
                <span class="badge bg-warning text-dark"><%= f %></span>
              <% }) %>
            </div>
          </div>
          <% } %>

          <div class="mb-4">
            <h6 class="fw-bold">Alasan Rekomendasi</h6>

            <% if (rekomendasi.alasan && rekomendasi.alasan.length > 0) { %>
              <ul class="list-group">
                <% rekomendasi.alasan.forEach(a => { %>
                  <li class="list-group-item"><%= a %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>

          <%
          function buildNarasi(aiPath, faktor, user) {
            let hasil = [];

            (aiPath || []).forEach(step => {

              if (step.includes("Konsentrasi")) {
                if (user.konsentrasi >= 4) {
                  hasil.push("konsentrasi kamu sudah cukup baik");
                } else {
                  hasil.push("konsentrasi kamu masih perlu ditingkatkan");
                }
              }

              if (step.includes("Konsistensi")) {
                if (user.konsistensi >= 4) {
                  hasil.push("konsistensi belajar kamu sudah cukup stabil");
                } else {
                  hasil.push("konsistensi belajar kamu masih belum stabil");
                }
              }

              if (step.includes("Durasi")) {
                if (user.durasi >= 4) {
                  hasil.push("durasi belajar kamu sudah cukup optimal");
                } else {
                  hasil.push("durasi belajar kamu masih terbatas");
                }
              }

              if (step.includes("Kelelahan")) {
                if (user.kelelahan >= 4) {
                  hasil.push("kamu cenderung mudah merasa lelah saat belajar");
                } else {
                  hasil.push("kondisi fisik kamu cukup mendukung untuk belajar");
                }
              }

              if (step.includes("Lingkungan")) {
                if (user.lingkungan >= 4) {
                  hasil.push("lingkungan belajar kamu sudah cukup kondusif");
                } else {
                  hasil.push("lingkungan belajar kamu kurang mendukung");
                }
              }

              if (step.includes("Gangguan")) {
                if (user.gangguan >= 4) {
                  hasil.push("terdapat cukup banyak gangguan saat belajar");
                } else {
                  hasil.push("gangguan saat belajar relatif rendah");
                }
              }

            });

            // hapus duplikat
            hasil = [...new Set(hasil)];

            if (hasil.length === 0) {
              return `
                Sistem menganalisis kondisi belajar kamu secara keseluruhan
                dan memberikan rekomendasi yang paling sesuai untuk meningkatkan efektivitas belajar.
              `;
            }

            return `
              Berdasarkan analisis sistem, ditemukan bahwa ${hasil.join(", ")}.
              
              Kondisi ini mempengaruhi efektivitas proses belajar kamu.
              Oleh karena itu, sistem merekomendasikan metode belajar yang lebih sesuai,
              terutama dengan mempertimbangkan faktor ${faktor.join(" dan ")}.
            `;
          }
          const narasiAI = buildNarasi(
            rekomendasi.ai_path,
            rekomendasi.faktor,
            data
          );
          %>

          <div class="mb-4">
            <h6 class="fw-bold">Penjelasan</h6>
            <div class="p-3 border rounded-3 bg-light">
              <%= narasiAI %>
            </div>
          </div>

          <div class="mb-4">
            <h6 class="fw-bold">Tips untuk Kamu</h6>

            <% if (rekomendasi.tips && rekomendasi.tips.length > 0) { %>
              <ul class="list-group">
                <% rekomendasi.tips.forEach(t => { %>
                  <li class="list-group-item">- <%= t %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>

          <% } %>

        </div>

        <div class="text-center pb-4">
          <a href="/" class="btn btn-success px-4 py-2 rounded-pill">
            ⬅ Kembali
          </a>
        </div>

      </div>

    </div>
  </div>
</div>