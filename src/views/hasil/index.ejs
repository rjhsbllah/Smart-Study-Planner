<div class="container my-5">
  <div class="text-center mb-5">
    <h2 class="fw-bold">Hasil Rekomendasi Belajar</h2>
    <p class="text-muted">
      Analisis kebiasaan belajar & rekomendasi personal untuk kamu
    </p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="p-4 text-center text-white header-gradient">
          <h3 class="fw-bold mb-1"><%= data.nama %></h3>
          <div class="mt-2">
            <span class="badge bg-light text-dark me-2"><%= data.status %></span>
            <span class="badge bg-light text-dark"><%= data.aktivitas %></span>
          </div>
        </div>

        <div class="text-center py-4">
          <h6 class="text-muted mb-2">Skor Performa Belajar</h6>

          <div class="score-wrapper">
            <div class="score-circle">
              <%= skor %>%
            </div>
          </div>

          <p class="mt-3 fw-semibold">
            <% if (skor >= 80) { %>
              Sangat Optimal
            <% } else if (skor >= 60) { %>
              Cukup Baik
            <% } else { %>
              Perlu Perbaikan
            <% } %>
          </p>

          <p class="text-muted small">
            <% if (skor >= 80) { %>
              Kondisi belajar kamu sudah sangat baik dan efektif.
            <% } else if (skor >= 60) { %>
              Kondisi belajar cukup baik namun masih bisa ditingkatkan.
            <% } else { %>
              Kondisi belajar perlu diperbaiki agar lebih optimal.
            <% } %>
          </p>
        </div>

        <hr class="mx-4"/>

        <div class="px-4 pb-4">

          <h5 class="fw-bold text-center mb-4">Rekomendasi Belajar</h5>

          <% if (rekomendasi && Object.keys(rekomendasi).length > 0) { %>

          <div class="row g-3 mb-4">

            <div class="col-md-6">
              <div class="p-3 border rounded-3 bg-light h-100 text-center">
                <small class="text-muted">Metode</small>
                <h6 class="fw-bold mt-1"><%= rekomendasi.judul %></h6>
              </div>
            </div>

            <div class="col-md-6">
              <div class="p-3 border rounded-3 bg-light h-100 text-center">
                <small class="text-muted">Waktu Ideal</small>
                <h6 class="fw-bold mt-1"><%= rekomendasi.waktu %></h6>
              </div>
            </div>

            <div class="col-12">
              <div class="p-3 border rounded-3 bg-light">
                <small class="text-muted">Pola Belajar</small>
                <p class="mb-0"><%= rekomendasi.pola %></p>
              </div>
            </div>

          </div>

          <% if (rekomendasi.faktor && rekomendasi.faktor.length > 0) { %>
          <div class="mb-4">
            <h6 class="fw-bold">Faktor Dominan</h6>
            <div class="d-flex flex-wrap gap-2 mt-2">
              <% rekomendasi.faktor.forEach(f => { %>
                <span class="badge bg-warning text-dark">
                  <%= f %>
                </span>
              <% }) %>
            </div>
          </div>
          <% } %>

          <div class="mb-4">
            <h6 class="fw-bold">Penjelasan</h6>
            <div class="p-3 border rounded-3 bg-light">
              <%= rekomendasi.deskripsi %>
            </div>
          </div>

          <div class="mb-4">
            <h6 class="fw-bold">Alasan Rekomendasi</h6>

            <% if (rekomendasi.alasan && rekomendasi.alasan.length > 0) { %>
              <ul class="list-group">
                <% rekomendasi.alasan.forEach(a => { %>
                  <li class="list-group-item">
                    ➡ <%= a %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted">
                Berdasarkan analisis kondisi belajar kamu.
              </p>
            <% } %>
          </div>

          <div class="mb-4">
            <h6 class="fw-bold">Tips Praktis</h6>

            <% if (rekomendasi.tips && rekomendasi.tips.length > 0) { %>
              <ul class="list-group">
                <% rekomendasi.tips.forEach(t => { %>
                  <li class="list-group-item">
                    ✔ <%= t %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted">Tidak ada tips</p>
            <% } %>
          </div>

          <% } else { %>
            <p class="text-muted text-center">Tidak ada rekomendasi tersedia</p>
          <% } %>

        </div>

        <div class="text-center px-4 pb-3">
          <small class="text-muted">
            Sistem ini menggunakan metode SAW dan pendekatan Explainable AI untuk menghasilkan rekomendasi yang transparan.
          </small>
        </div>

        <div class="text-center pb-4">
          <a href="/" class="btn btn-success px-4 py-2 rounded-pill">
            ⬅ Kembali
          </a>
        </div>

      </div>

    </div>
  </div>
</div>